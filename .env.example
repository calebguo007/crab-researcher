# ---------- 应用基础 ----------
DEBUG=true
API_PREFIX=/api

# ---------- 数据库 ----------
POSTGRES_USER=crab
POSTGRES_PASSWORD=crab_secret_2026
POSTGRES_DB=crab_researcher
DATABASE_URL=postgresql+asyncpg://crab:crab_secret_2026@postgres:5432/crab_researcher
DATABASE_URL_SYNC=postgresql://crab:crab_secret_2026@postgres:5432/crab_researcher
REDIS_URL=redis://redis:6379

# ---------- LLM API Keys ----------
OPENAI_API_KEY=sk-your-openai-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
DEEPSEEK_API_KEY=sk-your-deepseek-key
MOONSHOT_API_KEY=sk-your-moonshot-key

# ---------- 消息平台 Webhook ----------
WECOM_WEBHOOK_URL=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=YOUR_KEY
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/YOUR_HOOK

# ---------- 安全 ----------
JWT_SECRET=your-super-secret-jwt-key-change-me
API_KEY=your-api-key-for-n8n

# ---------- 成本控制 ----------
MONTHLY_BUDGET_PER_USER=100
TOKEN_USAGE_ALERT_THRESHOLD=0.8
